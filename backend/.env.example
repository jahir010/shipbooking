DATABASE_URL=mysql://USERNAME:PASSWORD@HOST:4000/shipbooking?ssl=true
DB_SCHEME=mysql
DB_SSL=False
DB_SSLMODE=prefer
ENVIRONMENT=development
DB_GENERATE_SCHEMAS=True
RUN_STARTUP_SCHEMA_SYNC=True

APP_URL=https://out-beige-tau.vercel.app
API_PUBLIC_BASE_URL=https://shipbooking-api.onrender.com/api
BACKEND_CORS_ORIGINS=https://out-beige-tau.vercel.app,http://localhost:3000,http://127.0.0.1:3000

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX_MODE=True

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Auth notes:
# - Public registration allows customer and shipowner accounts.
# - The very first admin account can also be created through /api/auth/register
#   only when the database currently has no admin user.
